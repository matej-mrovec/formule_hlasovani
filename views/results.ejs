<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="UTF-8">
    <title>F1 2026 - Výsledky</title>
    <link rel="stylesheet" href="/style.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body>
    <div class="container">
        <h1>Výsledky ankety 2026</h1>
        
        <div class="chart-container">
            <h2>Popularita týmů</h2>
            <canvas id="teamChart"></canvas>
        </div>

        <div class="chart-container">
            <h2>Popularita jezdců</h2>
            <canvas id="driverChart"></canvas>
        </div>

        <h2>Historie hlasování</h2>
        <table>
            <thead>
                <tr>
                    <th>Čas</th>
                    <th>Tým</th>
                    <th>Jezdec</th>
                    <th>Komentář</th>
                </tr>
            </thead>
            <tbody>
                <% responses.reverse().forEach(r => { %>
                    <tr>
                        <td><%= r.timestamp %></td>
                        <td><strong><%= r.team %></strong></td>
                        <td><%= r.driver %></td>
                        <td><%= r.comment %></td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
        <a href="/">← Zpět k hlasování</a>
    </div>

    <script>
        // Načtení dat (bezpečné parsování pro EJS)
        const teamData = JSON.parse('<%- JSON.stringify(teamStats) %>');
        const driverData = JSON.parse('<%- JSON.stringify(driverStats) %>');

        const teamColors = {
            "Red Bull Racing": "#3671C6",
            "Ferrari": "#E80020",
            "Mercedes-AMG": "#27F4D2",
            "McLaren": "#FF8000",
            "Aston Martin": "#229971",
            "Audi": "#000000",
            "Cadillac": "#FFD700",
            "Williams": "#64C4FF",
            "Alpine": "#EC0374",
            "Haas": "#B6BABD",
            "RB": "#6692FF"
        };

        new Chart(document.getElementById('teamChart'), {
            type: 'bar',
            data: {
                labels: Object.keys(teamData),
                datasets: [{
                    data: Object.values(teamData),
                    backgroundColor: Object.keys(teamData).map(name => teamColors[name] || '#e10600')
                }]
            },
            options: { plugins: { legend: { display: false } } }
        });

        new Chart(document.getElementById('driverChart'), {
            type: 'y', 
            type: 'bar',
            data: {
                labels: Object.keys(driverData),
                datasets: [{
                    label: 'Hlasy',
                    data: Object.values(driverData),
                    backgroundColor: '#e10600' 
                }]
            },
            options: {
                indexAxis: 'y', //Tohle otočí graf na bok
                plugins: { legend: { display: false } }
            }
        });
    </script>
</body>
</html>
